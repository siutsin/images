{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits"
  ],
  "automerge": true,
  "minimumReleaseAge": "7 day",
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchPackageNames": ["dataaxiom/ghcr-cleanup-action"],
      "abandonmentThreshold": null
    }
  ]
}
